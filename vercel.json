{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "/",           "dest": "/index.html"      },
    { "src": "/about",      "dest": "/about.html"      },
    { "src": "/experience", "dest": "/experience.html" },
    { "src": "/skills",     "dest": "/skills.html"     },
    { "src": "/contact",    "dest": "/contact.html"    },
    { "src": "/(.*)\\.html","dest": "/$1.html"         }
  ]
}
